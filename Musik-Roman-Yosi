<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Roman Yosi Music</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
font-family:'Poppins',sans-serif;
background:#000;
color:white;
overflow-x:hidden;
}

body::before{
content:"";
position:fixed;
width:100%;
height:100%;
background:
linear-gradient(rgba(0,0,0,.75),rgba(0,0,0,.9)),
url('https://images.unsplash.com/photo-1493225457124-a3eb161ffa5f?q=80&w=2070&auto=format&fit=crop');
background-size:cover;
background-position:center;
z-index:-1;
filter:blur(2px);
}

.container{
max-width:1200px;
margin:auto;
padding:0 20px;
}

header{
padding:30px 0;
}

.navbar{
display:flex;
justify-content:space-between;
align-items:center;
}

.logo{
font-size:32px;
font-weight:800;
display:flex;
align-items:center;
gap:10px;
}

.logo span{
color:#1DB954;
}

.menu{
display:flex;
gap:35px;
}

.menu a{
text-decoration:none;
color:white;
font-weight:500;
transition:.3s;
}

.menu a:hover{
color:#1DB954;
}

.hero{
display:flex;
align-items:center;
justify-content:space-between;
gap:60px;
padding:60px 0;
flex-wrap:wrap;
}

.hero-image{
position:relative;
}

.hero-image img{
width:360px;
height:360px;
object-fit:cover;
border-radius:50%;
border:4px solid #9db7ff;
box-shadow:0 0 60px #7aa2ff;
}

.blue-check{
position:absolute;
bottom:20px;
right:10px;
background:#2f8cff;
width:65px;
height:65px;
border-radius:50%;
display:flex;
align-items:center;
justify-content:center;
font-size:35px;
font-weight:bold;
box-shadow:0 0 20px #2f8cff;
}

.hero-text{
flex:1;
min-width:300px;
}

.top-title{
color:#1DB954;
font-size:18px;
font-weight:600;
margin-bottom:15px;
}

.hero-text h1{
font-size:80px;
line-height:1;
margin-bottom:20px;
font-weight:800;
}

.verify-inline{
background:#2f8cff;
padding:8px 14px;
border-radius:50px;
font-size:24px;
margin-left:10px;
}

.green-line{
width:120px;
height:5px;
background:#1DB954;
border-radius:50px;
margin-bottom:25px;
}

.bio{
font-size:24px;
line-height:1.8;
color:#ddd;
max-width:700px;
}

.buttons{
margin-top:35px;
display:flex;
gap:20px;
flex-wrap:wrap;
}

.btn{
padding:16px 34px;
border-radius:40px;
font-size:18px;
font-weight:600;
text-decoration:none;
transition:.3s;
}

.spotify{
background:#1DB954;
color:black;
}

.follow{
border:2px solid #777;
color:white;
}

.btn:hover{
transform:scale(1.05);
}

.socials{
margin-top:35px;
display:flex;
gap:35px;
flex-wrap:wrap;
}

.socials a{
color:white;
text-decoration:none;
font-size:18px;
display:flex;
align-items:center;
gap:10px;
}

.section{
padding:30px 0 60px;
}

.section-title{
text-align:center;
font-size:48px;
font-weight:800;
margin-bottom:40px;
}

.green-center{
width:90px;
height:5px;
background:#1DB954;
margin:15px auto;
border-radius:50px;
}

.card{
background:rgba(15,15,15,.95);
border:1px solid #222;
border-radius:28px;
padding:25px;
display:flex;
align-items:center;
justify-content:space-between;
gap:30px;
margin-bottom:30px;
backdrop-filter:blur(10px);
flex-wrap:wrap;
}

.song-left{
display:flex;
gap:20px;
align-items:center;
}

.song-left img{
width:230px;
border-radius:18px;
}

.song-info h3{
font-size:40px;
margin-bottom:10px;
}

.song-info p{
color:#bbb;
font-size:20px;
margin-bottom:20px;
}

.preview{
padding:12px 28px;
border:1px solid #555;
border-radius:12px;
display:inline-block;
}

.spotify-player{
flex:1;
min-width:320px;
}

.spotify-player iframe{
width:100%;
height:152px;
border:none;
border-radius:16px;
}

footer{
padding:50px 20px;
text-align:center;
color:#aaa;
font-size:18px;
}

@media(max-width:900px){

.hero{
justify-content:center;
text-align:center;
}

.hero-text h1{
font-size:52px;
}

.hero-image img{
width:270px;
height:270px;
}

.card{
justify-content:center;
}

.song-left{
flex-direction:column;
text-align:center;
}

.song-left img{
width:100%;
max-width:280px;
}

}

</style>
</head>

